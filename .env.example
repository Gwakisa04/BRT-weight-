# Copy to .env.local for local development (never commit .env.local)

# Backend API (browser + server-side fetches)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
BACKEND_URL=http://localhost:3001

# Socket.IO (live weight / vehicle location)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# How often the UI polls vehicle locations on map routes (ms)
NEXT_PUBLIC_GPS_POLL_INTERVAL_MS=5000
