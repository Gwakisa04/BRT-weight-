# Copy to .env.local for local dev, or set in Render Static Site → Environment.
# Static deploy: only NEXT_PUBLIC_* vars are required (no BACKEND_URL).

# REST API (browser)
NEXT_PUBLIC_API_URL=https://brt-weight-backend.onrender.com/api

# Socket.IO (live GPS / weight)
NEXT_PUBLIC_SOCKET_URL=https://brt-weight-backend.onrender.com

# Vehicle map poll interval (ms)
NEXT_PUBLIC_GPS_POLL_INTERVAL_MS=5000

# --- Local backend (uncomment for npm run dev against localhost) ---
# NEXT_PUBLIC_API_URL=http://localhost:3001/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
